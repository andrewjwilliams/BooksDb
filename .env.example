APP_NAME=BooksDb
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://booksdb.example.com
LIBRARY_NAME="My Library"

# Label printer (Brother QL series)
# Set to the printer's static LAN IP. If unset, the print endpoint will
# return a clear "printer not configured" error.
LABEL_PRINTER_HOST=
LABEL_PRINTER_TAPE=62
LABEL_PRINTER_SIDECAR_URL=http://127.0.0.1:5151
# CUPS media name for the label queue.  Use Custom.62x35mm for 62mm continuous
# tape: the extra 6mm (3mm each end) is the printer's mandatory blank leading/
# trailing tape before/after the cut.  The 696×342px canvas fits in the
# resulting 28.94mm imageable area at 300 DPI.
LABEL_PRINTER_MEDIA=Custom.62x35mm
LABEL_PRINTER_CUT=EndOfJob

LOG_CHANNEL=stderr

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=booksdb
DB_USERNAME=booksdb
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
